{
  "name": "strays-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Code-first team ownership for TypeScript. Find a home for every line of code.",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*",
    "examples/*",
    "integration-tests/*"
  ],
  "scripts": {
    "test": "turbo run test",
    "test:contract": "turbo run test --filter=@strays/build",
    "test:integration": "turbo run test --filter='@strays-it/*'",
    "install:fast": "bun install --omit=optional",
    "lint": "bunx oxlint",
    "format": "bunx oxfmt",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^25.6.0",
    "@types/picomatch": "^4.0.3",
    "effect": "^3.21.2",
    "esbuild": "^0.28.0",
    "oxlint": "^0.15.0",
    "turbo": "^2.5.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "picomatch": "^4.0.4",
    "ts-morph": "^28.0.0"
  }
}
