{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "tsconfig.base.json",
    "tsdown.base.mjs",
    "bunfig.toml",
    ".oxlintrc.json"
  ],
  "tasks": {
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^typecheck"
      ],
      "outputs": []
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "check:publish": {
      "dependsOn": [
        "build"
      ],
      "outputs": []
    }
  }
}
