{
  "name": "@ownheim/cli",
  "version": "0.1.0",
  "description": "ownheim CLI: generate | check | coverage | trace | diff",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "ownheim": "./dist/index.mjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./commands/generate": {
      "import": {
        "types": "./dist/commands/generate.d.mts",
        "default": "./dist/commands/generate.mjs"
      },
      "require": {
        "types": "./dist/commands/generate.d.cts",
        "default": "./dist/commands/generate.cjs"
      }
    },
    "./commands/check": {
      "import": {
        "types": "./dist/commands/check.d.mts",
        "default": "./dist/commands/check.mjs"
      },
      "require": {
        "types": "./dist/commands/check.d.cts",
        "default": "./dist/commands/check.cjs"
      }
    },
    "./commands/coverage": {
      "import": {
        "types": "./dist/commands/coverage.d.mts",
        "default": "./dist/commands/coverage.mjs"
      },
      "require": {
        "types": "./dist/commands/coverage.d.cts",
        "default": "./dist/commands/coverage.cjs"
      }
    },
    "./commands/trace": {
      "import": {
        "types": "./dist/commands/trace.d.mts",
        "default": "./dist/commands/trace.mjs"
      },
      "require": {
        "types": "./dist/commands/trace.d.cts",
        "default": "./dist/commands/trace.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ownheim/build": "workspace:*",
    "@ownheim/core": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ownheim/ownheim.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/ownheim/ownheim#readme",
  "bugs": {
    "url": "https://github.com/ownheim/ownheim/issues"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.18.0"
  }
}
