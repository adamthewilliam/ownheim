{
  "name": "@ownheim/build",
  "version": "0.1.0",
  "description": "ownheim — AST walker, rule resolver, CODEOWNERS + manifest generators, esbuild plugin",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./analyzeSourceFile": {
      "import": {
        "types": "./dist/analyzeSourceFile.d.mts",
        "default": "./dist/analyzeSourceFile.mjs"
      },
      "require": {
        "types": "./dist/analyzeSourceFile.d.cts",
        "default": "./dist/analyzeSourceFile.cjs"
      }
    },
    "./resolveRules": {
      "import": {
        "types": "./dist/resolveRules.d.mts",
        "default": "./dist/resolveRules.mjs"
      },
      "require": {
        "types": "./dist/resolveRules.d.cts",
        "default": "./dist/resolveRules.cjs"
      }
    },
    "./auditOwnership": {
      "import": {
        "types": "./dist/auditOwnership.d.mts",
        "default": "./dist/auditOwnership.mjs"
      },
      "require": {
        "types": "./dist/auditOwnership.d.cts",
        "default": "./dist/auditOwnership.cjs"
      }
    },
    "./generateCodeowners": {
      "import": {
        "types": "./dist/generateCodeowners.d.mts",
        "default": "./dist/generateCodeowners.mjs"
      },
      "require": {
        "types": "./dist/generateCodeowners.d.cts",
        "default": "./dist/generateCodeowners.cjs"
      }
    },
    "./generateManifest": {
      "import": {
        "types": "./dist/generateManifest.d.mts",
        "default": "./dist/generateManifest.mjs"
      },
      "require": {
        "types": "./dist/generateManifest.d.cts",
        "default": "./dist/generateManifest.cjs"
      }
    },
    "./generateArtifacts": {
      "import": {
        "types": "./dist/generateArtifacts.d.mts",
        "default": "./dist/generateArtifacts.mjs"
      },
      "require": {
        "types": "./dist/generateArtifacts.d.cts",
        "default": "./dist/generateArtifacts.cjs"
      }
    },
    "./esbuildPlugin": {
      "import": {
        "types": "./dist/esbuildPlugin.d.mts",
        "default": "./dist/esbuildPlugin.mjs"
      },
      "require": {
        "types": "./dist/esbuildPlugin.d.cts",
        "default": "./dist/esbuildPlugin.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ownheim/core": "0.1.0",
    "ts-morph": "^24.0.0",
    "picomatch": "^4.0.2"
  },
  "peerDependencies": {
    "esbuild": "^0.24.0"
  },
  "devDependencies": {
    "@types/picomatch": "^3.0.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ownheim/ownheim.git",
    "directory": "packages/build"
  },
  "homepage": "https://github.com/ownheim/ownheim#readme",
  "bugs": {
    "url": "https://github.com/ownheim/ownheim/issues"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    }
  }
}
