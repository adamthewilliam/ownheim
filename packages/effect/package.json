{
  "name": "@ownheim/effect",
  "version": "0.1.0",
  "description": "ownheim — Effect-TS error ownership and tracing adapters",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./ownedBy": {
      "import": {
        "types": "./dist/ownedBy.d.mts",
        "default": "./dist/ownedBy.mjs"
      },
      "require": {
        "types": "./dist/ownedBy.d.cts",
        "default": "./dist/ownedBy.cjs"
      }
    },
    "./Logging": {
      "import": {
        "types": "./dist/Logging.d.mts",
        "default": "./dist/Logging.mjs"
      },
      "require": {
        "types": "./dist/Logging.d.cts",
        "default": "./dist/Logging.cjs"
      }
    },
    "./Tracer": {
      "import": {
        "types": "./dist/Tracer.d.mts",
        "default": "./dist/Tracer.mjs"
      },
      "require": {
        "types": "./dist/Tracer.d.cts",
        "default": "./dist/Tracer.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ownheim/core": "0.1.0"
  },
  "peerDependencies": {
    "effect": "^3.10.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ownheim/ownheim.git",
    "directory": "packages/effect"
  },
  "homepage": "https://github.com/ownheim/ownheim#readme",
  "bugs": {
    "url": "https://github.com/ownheim/ownheim/issues"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
