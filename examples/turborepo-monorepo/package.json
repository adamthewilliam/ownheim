    "test": "bun test"
  },
  "dependencies": {
    "@ownheim/core": "workspace:*"
  },
  "devDependencies": {
    "@ownheim/cli": "workspace:*",
    "turbo": "^2.5.0",
    "typescript": "^5.6.0"
  }
}
